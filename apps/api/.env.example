NODE_ENV=development

# Server
PORT=4233

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=bob
DB_PASSWORD=bob_secret
DB_NAME=bob_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# AI assistant — DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional overrides:
# DEEPSEEK_MODEL=deepseek-chat        # or deepseek-reasoner
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google OAuth (sign in / sign up with Google).
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console
# and add this Authorized redirect URI: http://localhost:4233/auth/google/callback
# Google sign-in stays disabled until both values below are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional overrides (sensible defaults derived from PORT):
# GOOGLE_CALLBACK_URL=http://localhost:4233/auth/google/callback
# GOOGLE_SUCCESS_URL=http://localhost:4233/auth/google/success

# Search service URL (default: http://localhost:4234)
# SEARCH_SERVICE_URL=http://localhost:4234

# File storage
UPLOAD_DIR=./uploads
